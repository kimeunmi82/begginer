   "source": [
    "is_weekend = True\n",
    "has_homework = False\n",
    "\n",
    "if (is_weekend and not has_homework):\n",
    "    print(\"푹 쉴 수 있어요\")\n",
    "elif (is_weekend and has_homework):\n",
    "    print(\"숙제를 먼저 해요\")\n",
    "elif (not is_weekend and has_homework):\n",
    "    print(\"오늘도 바빠요\")\n",
    "else:\n",
    "    print(\"조금 여유롭네요\")"
   ]
  }
